# Development / planning
.planning/
tools/*
# Allow M2 env templates (no secrets; placeholders only) — per M2-02 Plan 01
!tools/env-template
!tools/env-staging-template
# Allow tracked M2 tools — atomic-deploy script (M2-02 Plan 04) + prepare-clean-repo (M2-05)
!tools/iam-deploy.sh
!tools/prepare-clean-repo.sh
!tools/m3-renames.map
# Allow Plesk-target tools (M3-Plesk port)
!tools/bootstrap-plesk.sh
!tools/iam-deploy-plesk.sh
media/dump iam/

